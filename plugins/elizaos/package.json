    "@agent-shield/solana": "workspace:*",
    "@agent-shield/custody-crossmint": "workspace:*",
    "@solana/web3.js": "^1.95.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
