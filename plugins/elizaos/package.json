  "description": "AgentShield plugin for ElizaOS — shield() wrapper actions, providers, and policy evaluators",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
